# ─────────────────────────────────────────────────────────────────────────────
# Fichier d'exemple de configuration — NE PAS committer le fichier .env réel
# Copier ce fichier en .env et renseigner les valeurs.
# ─────────────────────────────────────────────────────────────────────────────

# Clé secrète Django (OBLIGATOIRE en production)
# Générer avec : python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=remplacer-par-une-cle-secrete-forte

# Mode debug — mettre False en production
DEBUG=False

# Hôtes autorisés (séparés par des virgules)
ALLOWED_HOSTS=recrutepro.ci,www.recrutepro.ci

# Proxy de confiance — mettre True si le serveur est derrière nginx/Cloudflare
BEHIND_PROXY=True

# Origines CSRF de confiance (séparées par des virgules)
CSRF_TRUSTED_ORIGINS=https://recrutepro.ci,https://www.recrutepro.ci

# URL publique du site (utilisée dans robots.txt et sitemap.xml)
SITE_URL=https://www.recrutepro.ci

# ── Redis (cache + Celery) ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Base de données MySQL ────────────────────────────────────────────────────
DB_NAME=recrutement_db
DB_USER=recrutement_user
DB_PASSWORD=mot-de-passe-mysql
DB_HOST=localhost
DB_PORT=3306

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
EMAIL_HOST_USER=noreply@example.com
EMAIL_HOST_PASSWORD=mot-de-passe-smtp
DEFAULT_FROM_EMAIL=MonApp <noreply@example.com>
ADMIN_EMAIL=admin@example.com

# ── OAuth Google ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth GitHub ─────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Google Gemini (adaptation IA de CV) ──────────────────────────────────────
# Cle gratuite : https://aistudio.google.com/apikey (tier gratuit Gemini Flash)
GEMINI_API_KEY=

# ── MinIO / S3 Object Storage ───────────────────────────────────────────────
# Mettre USE_MINIO=True pour activer le stockage objet (production)
USE_MINIO=False
MINIO_ENDPOINT_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_REGION=us-east-1
MINIO_USE_SSL=False
